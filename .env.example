# Copy to .env for local overrides (never commit .env).

# Local development (defaults are fine if unset)
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Production — required when DJANGO_DEBUG=False
# DJANGO_SECRET_KEY=generate-a-long-random-string
# DJANGO_ALLOWED_HOSTS=your-app.onrender.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com

# Production database (Render / Railway inject this automatically for Postgres)
# DATABASE_URL=postgres://user:pass@host:5432/dbname
